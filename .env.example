# Copy to .env and adjust paths if needed:
# cp .env.example .env

# MySQL (docker-compose defaults)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=dev
MYSQL_PASSWORD=devpassword
MYSQL_DATABASE=devdb

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
POSTGRES_DATABASE=devdb

# SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=DevPassword123!
MSSQL_DATABASE=devdb
MSSQL_TRUST_SERVER_CERTIFICATE=true

# SQLite (relative to workspace root; created by docker compose)
SQLITE_DB_PATH=data/dev.db

# Policy (MCP write operations — shared by all DB query servers)
ALLOW_INSERT_OPERATION=false
ALLOW_UPDATE_OPERATION=false
ALLOW_DELETE_OPERATION=false
ALLOW_DDL_OPERATION=false

# Excel
EXCEL_PAGING_CELLS_LIMIT=4000
